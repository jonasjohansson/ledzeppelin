{
  "$comment": "LED Zeppelin design tokens, mirrored from src/ui/ui.css :root. W3C-ish design-token shape so it maps cleanly to Figma Variable collections (Color / Spacing / Typography / Radius / Layout). Values are the resolved literals; aliases (green/amber/cyan = accent) are noted. Regenerate from ui.css if tokens change.",
  "color": {
    "surface": {
      "bg":          { "$type": "color", "$value": "#101114", "css": "--bg" },
      "panel":       { "$type": "color", "$value": "#1c1e22", "css": "--panel" },
      "panel-2":     { "$type": "color", "$value": "#26282d", "css": "--panel-2" },
      "hover":       { "$type": "color", "$value": "#33363c", "css": "--hover" },
      "panel-solid": { "$type": "color", "$value": "#1c1e22", "css": "--panel-solid" },
      "field-bg":    { "$type": "color", "$value": "#121317", "css": "--field-bg" }
    },
    "line": {
      "line":   { "$type": "color", "$value": "#33363e", "css": "--line" },
      "line-2": { "$type": "color", "$value": "#474c55", "css": "--line-2" }
    },
    "text": {
      "text":    { "$type": "color", "$value": "#f4f5f7", "css": "--text" },
      "muted":   { "$type": "color", "$value": "#a3aab4", "css": "--muted" },
      "faint":   { "$type": "color", "$value": "#737a84", "css": "--faint" },
      "readout": { "$type": "color", "$value": "#d7dbe0", "css": "--readout" }
    },
    "accent": {
      "accent":      { "$type": "color", "$value": "#e8a35c", "css": "--accent" },
      "accent-soft": { "$type": "color", "$value": "#33271a", "css": "--accent-soft" },
      "accent-text": { "$type": "color", "$value": "#f1d6bb", "css": "--accent-text" },
      "accent-line": { "$type": "color", "$value": "#54402b", "css": "--accent-line" }
    },
    "status": {
      "danger": { "$type": "color", "$value": "#ff6b6b", "css": "--danger" },
      "$note":  "green / amber / cyan all alias --accent (#e8a35c) in the warm-mono palette; per-controller canvas hues live in controllerColorMap, not here."
    }
  },
  "spacing": {
    "s1": { "$type": "dimension", "$value": "2px",  "css": "--s1" },
    "s2": { "$type": "dimension", "$value": "4px",  "css": "--s2" },
    "s3": { "$type": "dimension", "$value": "6px",  "css": "--s3" },
    "s4": { "$type": "dimension", "$value": "10px", "css": "--s4" },
    "s5": { "$type": "dimension", "$value": "14px", "css": "--s5" }
  },
  "radius": {
    "radius":    { "$type": "dimension", "$value": "3px", "css": "--radius" },
    "radius-sm": { "$type": "dimension", "$value": "2px", "css": "--radius-sm" }
  },
  "typography": {
    "family": {
      "ui-font": { "$type": "fontFamily", "$value": "Spline Sans Mono", "css": "--ui-font",
                   "$note": "MONO-FORWARD: one mono face for chrome AND data. Martian Mono is the swappable alt. --mono and --sans both alias this." }
    },
    "size": {
      "micro": { "$type": "dimension", "$value": "10px", "css": "--fs-micro" },
      "body":  { "$type": "dimension", "$value": "11px", "css": "--fs-body" },
      "ctrl":  { "$type": "dimension", "$value": "12px", "css": "--fs-ctrl" },
      "title": { "$type": "dimension", "$value": "13px", "css": "--fs-title" },
      "glyph": { "$type": "dimension", "$value": "15px", "css": "--fs-glyph" }
    },
    "weight": {
      "reg": { "$type": "number", "$value": 400, "css": "--fw-reg" },
      "med": { "$type": "number", "$value": 400, "css": "--fw-med", "$note": "single weight — no bold in UI text" }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.2,  "css": "--lh-tight" },
      "ctrl":  { "$type": "number", "$value": 1.4,  "css": "--lh-ctrl" },
      "ui":    { "$type": "number", "$value": 1.45, "css": "--lh-ui" }
    },
    "letterSpacing": {
      "caps": { "$type": "dimension", "$value": "0.1em",  "css": "--ls-caps" },
      "ui":   { "$type": "dimension", "$value": "0.04em", "css": "--ls-ui" }
    }
  },
  "layout": {
    "side-w":    { "$type": "dimension", "$value": "332px", "css": "--side-w",    "$note": "right panel width" },
    "layer-w":   { "$type": "dimension", "$value": "128px", "css": "--layer-w" },
    "clip-w":    { "$type": "dimension", "$value": "96px",  "css": "--clip-w" },
    "clip-h":    { "$type": "dimension", "$value": "84px",  "css": "--clip-h" },
    "row-h":     { "$type": "dimension", "$value": "26px",  "css": "--row-h",     "$note": "one label·control row height" },
    "ctrl-h":    { "$type": "dimension", "$value": "22px",  "css": "--ctrl-h",    "$note": "one control height (fields/selects/buttons)" },
    "col-label": { "$type": "dimension", "$value": "84px",  "css": "--col-label" },
    "col-val":   { "$type": "dimension", "$value": "44px",  "css": "--col-val" },
    "slider-w":  { "$type": "dimension", "$value": "120px", "css": "--slider-w" }
  }
}
